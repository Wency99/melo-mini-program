.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  overflow: hidden;
}

.preview {
  position: fixed;
  left: 0;
  right: 0;
  width: 100%;
  overflow: hidden;
  background: #000000;
}

.photo {
  position: relative;
  width: 100%;
  height: 100%;
}

.hud-top {
  position: absolute;
  top: 140rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 50;
}

.time {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--melo-text-inverse);
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
}

.footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #000000;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tag-location-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.72);
  text-align: left;
}

.input-box {
  position: relative;
}

.caption-input {
  width: 100%;
  min-height: 160rpx;
  max-height: 240rpx;
  background: var(--melo-bg-surface);
  border-radius: var(--melo-radius-md);
  padding: 24rpx 112rpx 34rpx 24rpx;
  font-size: 28rpx;
  color: var(--melo-text-primary);
  box-sizing: border-box;
  border: 1rpx solid var(--melo-border);
}

.btn-send {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-circle {
  width: 76rpx;
  height: 76rpx;
  background: var(--melo-brand);
  border-radius: var(--melo-radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--melo-transition);
}

.send-symbol {
  color: var(--melo-text-primary);
  font-size: 40rpx;
  line-height: 40rpx;
  font-weight: 700;
  transform: translateX(2rpx);
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F9F9FB;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-animation {
  width: 220rpx;
  height: 220rpx;
}

.loading-text {
  margin-top: 18rpx;
  font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0;
  color: var(--melo-text-primary);
}
