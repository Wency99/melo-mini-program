.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  overflow: hidden;
}

.camera-frame {
  position: fixed;
  left: 0;
  right: 0;
  width: 100%;
  overflow: hidden;
  background: #000000;
  transition: height 200ms ease, top 200ms ease, opacity 200ms ease;
}

.camera-frame.is-dim {
  opacity: 0.4;
}

.camera {
  width: 100%;
  height: 100%;
}

.frame-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
  pointer-events: none;
}

.corner {
  position: absolute;
  width: 54rpx;
  height: 54rpx;
}

.corner-tl {
  top: 18rpx;
  left: 18rpx;
}

.corner-tr {
  top: 18rpx;
  right: 18rpx;
}

.corner-bl {
  left: 18rpx;
  bottom: 18rpx;
}

.corner-br {
  right: 18rpx;
  bottom: 18rpx;
}

.corner-line {
  position: absolute;
  background: var(--melo-brand);
  border-radius: 6rpx;
}

.corner-h {
  width: 54rpx;
  height: 6rpx;
}

.corner-v {
  width: 6rpx;
  height: 54rpx;
}

.corner-tl .corner-h,
.corner-tl .corner-v {
  top: 0;
  left: 0;
}

.corner-tr .corner-h {
  top: 0;
  right: 0;
}

.corner-tr .corner-v {
  top: 0;
  right: 0;
}

.corner-bl .corner-h {
  left: 0;
  bottom: 0;
}

.corner-bl .corner-v {
  left: 0;
  bottom: 0;
}

.corner-br .corner-h,
.corner-br .corner-v {
  right: 0;
  bottom: 0;
}

.state-panel {
  position: absolute;
  left: 56rpx;
  right: 56rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.state-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.state-hint {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 36rpx;
  color: rgba(255, 255, 255, 0.78);
}

.hud-top {
  position: fixed;
  top: 100rpx;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.time {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--melo-text-inverse);
}

.city {
  font-size: 28rpx;
  color: var(--melo-white-90);
  margin-top: var(--melo-space-xs);
  padding: var(--melo-space-xs) var(--melo-space-md);
  background: rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(10rpx);
  border-radius: var(--melo-radius-md);
}

.controls {
  position: fixed;
  bottom: 80rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 var(--melo-space-xl);
  z-index: 10;
}

.btn-nav {
  width: 100rpx;
  height: 100rpx;
  background: var(--melo-white-20);
  border-radius: var(--melo-radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.btn-nav.is-disabled,
.btn-capture.is-disabled {
  opacity: 0.4;
}

.control-active {
  opacity: 0.6;
}

.nav-icon {
  width: 60rpx;
  height: 60rpx;
}

.space-icon {
  width: 64rpx;
  height: 64rpx;
}

.switch-icon {
  width: 62rpx;
  height: 62rpx;
}

.btn-capture {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.capture-ring {
  width: 130rpx;
  height: 130rpx;
  border-radius: var(--melo-radius-full);
  border: 6rpx solid var(--melo-brand);
  display: flex;
  align-items: center;
  justify-content: center;
}

.capture-inner {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--melo-radius-full);
  background: var(--melo-brand);
}

.btn-switch-wrapper {
  position: fixed;
  right: 110rpx;
  bottom: 260rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}
