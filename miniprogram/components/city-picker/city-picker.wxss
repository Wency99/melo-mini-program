.city-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.city-picker-panel {
  width: 100%;
  height: 85vh;
  background: var(--melo-bg-page, #FDFDF7);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx 16rpx;
  position: relative;
  flex-shrink: 0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--melo-text-primary, #3F3F3F);
}

.picker-close {
  position: absolute;
  right: 40rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 28rpx;
  color: var(--melo-text-secondary, #787878);
}

.search-bar {
  padding: 16rpx 40rpx 20rpx;
  flex-shrink: 0;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--melo-bg-surface, #FFFFFF);
  border-radius: 40rpx;
  padding: 0 28rpx;
  height: 72rpx;
  border: 1rpx solid var(--melo-border, rgba(0,0,0,0.05));
  box-shadow: var(--melo-shadow-card, 0 4rpx 20rpx rgba(0,0,0,0.03));
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--melo-text-primary, #3F3F3F);
}

.picker-body {
  flex: 1;
  padding: 0 40rpx 40rpx;
}

.section-label {
  font-size: 24rpx;
  color: var(--melo-text-muted, #A8A8A8);
  padding: 20rpx 0 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.city-list {
  padding-bottom: env(safe-area-inset-bottom);
}

.city-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--melo-border, rgba(0,0,0,0.05));
}

.city-item:active {
  opacity: 0.6;
}

.city-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--melo-text-primary, #3F3F3F);
}

.city-country {
  font-size: 24rpx;
  color: var(--melo-text-muted, #A8A8A8);
}

.empty-result {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--melo-text-muted, #A8A8A8);
}
